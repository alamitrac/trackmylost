# Frontend talks to Laravel through the Vite dev proxy (see vite.config.js),
# so the baseURL is a relative path — no CORS in dev. Override only if you
# need to point at a remote backend (CORS must then be configured server-side).
VITE_API_URL=/api

# Where the Vite dev proxy forwards /api requests. Defaults to the local
# Laravel dev server; override if `php artisan serve` runs elsewhere.
VITE_API_PROXY=http://127.0.0.1:8000
